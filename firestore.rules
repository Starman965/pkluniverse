rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function memberPath(clubId, teamId) {
      return /databases/$(database)/documents/clubs/$(clubId)/teams/$(teamId)/members/$(request.auth.uid);
    }

    function memberDoc(clubId, teamId) {
      return get(memberPath(clubId, teamId));
    }

    function userProfileDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isTeamMember(clubId, teamId) {
      return signedIn() && exists(memberPath(clubId, teamId));
    }

    function hasTeamRole(clubId, teamId, roles) {
      return isTeamMember(clubId, teamId) && memberDoc(clubId, teamId).data.role in roles;
    }

    function isManager(clubId, teamId) {
      return hasTeamRole(clubId, teamId, ['captain', 'coCaptain']);
    }

    function isCaptain(clubId, teamId) {
      return hasTeamRole(clubId, teamId, ['captain']);
    }

    function isBootstrapPlatformAdmin() {
      return signedIn()
        && request.auth.token.email in ['demandgendave@gmail.com'];
    }

    function isPlatformAdmin() {
      return isBootstrapPlatformAdmin();
    }

    function isClubAdmin(clubId) {
      return signedIn()
        && exists(/databases/$(database)/documents/clubs/$(clubId)/admins/$(request.auth.uid));
    }

    function isClubApprover(clubId) {
      return isPlatformAdmin() || isClubAdmin(clubId);
    }

    function isAdminContext() {
      return isPlatformAdmin();
    }

    function isApprovedClubTeam(clubId, teamId) {
      return signedIn()
        && get(/databases/$(database)/documents/clubs/$(clubId)/teams/$(teamId)).data.status == 'active'
        && get(/databases/$(database)/documents/clubs/$(clubId)/teams/$(teamId)).data.affiliationStatus == 'approved'
        && get(/databases/$(database)/documents/clubs/$(clubId)/teams/$(teamId)).data.approvedClubSlug is string
        && get(/databases/$(database)/documents/clubs/$(clubId)/teams/$(teamId)).data.approvedClubSlug != 'independent';
    }

    function isReservedClubCreate(clubId) {
      return clubId in ['independent', 'blackhawk-country-club'];
    }

    function safeAdminNotificationCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'captainEmail',
          'captainEmails',
          'captainName',
          'captainNames',
          'clubSlug',
          'createdAt',
          'createdByEmail',
          'createdByName',
          'createdByUid',
          'message',
          'metadata',
          'status',
          'teamName',
          'teamSlug',
          'title',
          'type',
        ])
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.status == 'new'
        && request.resource.data.type in [
          'team.created',
          'teamMember.joined',
          'clubAffiliation.requested',
          'challenge.created',
          'challenge.cancelled',
          'challenge.accepted',
          'challenge.matchRemoved',
        ]
        && request.resource.data.captainEmail is string
        && request.resource.data.captainEmails is string
        && request.resource.data.captainName is string
        && request.resource.data.captainNames is string
        && request.resource.data.title is string
        && request.resource.data.message is string
        && request.resource.data.metadata is map;
    }

    function safeActivityLogCreate() {
      return signedIn()
        && request.resource.data.keys().hasOnly([
          'actorId',
          'clubId',
          'metadata',
          'targetId',
          'teamId',
          'timestamp',
          'type',
        ])
        && request.resource.data.actorId == request.auth.uid
        && request.resource.data.actorId is string
        && request.resource.data.clubId is string
        && request.resource.data.metadata is map
        && request.resource.data.targetId is string
        && request.resource.data.teamId is string
        && request.resource.data.timestamp == request.time
        && request.resource.data.type in [
          'challenge_created',
          'challenge_accepted',
          'challenge_declined',
          'match_scheduled',
          'match_completed',
          'score_reported',
          'team_created',
          'player_added',
          'player_joined_team',
          'event_created',
          'event_registered',
          'standings_updated',
        ];
    }

    function safeTeamMemberCountIncrement(clubId, teamId) {
      return signedIn()
        && (
          (
            resource.data.memberCount is int
            && resource.data.memberCount < 2
            && request.resource.data.memberCount == resource.data.memberCount + 1
          )
          || (
            !resource.data.keys().hasAny(['memberCount'])
            && request.resource.data.memberCount == 2
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberCount',
          'updatedAt',
        ]);
    }

    function safeTeamMemberCountDecrement(clubId, teamId) {
      return signedIn()
        && resource.data.memberCount is int
        && resource.data.memberCount > 0
        && request.resource.data.memberCount == resource.data.memberCount - 1
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'memberCount',
          'updatedAt',
        ]);
    }

    function canReadActivityLog() {
      return isPlatformAdmin()
        || (
          resource.data.clubId is string
          && resource.data.teamId is string
          && resource.data.teamId != ''
          && isTeamMember(resource.data.clubId, resource.data.teamId)
        )
        || (
          signedIn()
          && resource.data.clubId is string
          && hasActiveApprovedTeamInClub(resource.data.clubId)
        );
    }

    function hasActiveApprovedTeamInClub(activityClubId) {
      let profile = userProfileDoc(request.auth.uid);
      let activeClubId = profile.data.lastActiveClubId;
      let activeTeamId = profile.data.lastActiveTeamId;

      return signedIn()
        && activeClubId is string
        && activeTeamId is string
        && exists(memberPath(activeClubId, activeTeamId))
        && get(/databases/$(database)/documents/clubs/$(activeClubId)/teams/$(activeTeamId)).data.status == 'active'
        && get(/databases/$(database)/documents/clubs/$(activeClubId)/teams/$(activeTeamId)).data.affiliationStatus == 'approved'
        && get(/databases/$(database)/documents/clubs/$(activeClubId)/teams/$(activeTeamId)).data.approvedClubSlug == activityClubId;
    }

    function hasActiveTeamInClub(clubId) {
      let profile = userProfileDoc(request.auth.uid);
      let activeTeamId = profile.data.lastActiveTeamId;

      return signedIn()
        && profile.data.lastActiveClubId == clubId
        && activeTeamId is string
        && exists(memberPath(clubId, activeTeamId));
    }

    function safeSelfMembershipUpdate(uid) {
      return isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.clubSlug == resource.data.clubSlug
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.teamSlug == resource.data.teamSlug
        && request.resource.data.teamName == resource.data.teamName
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.joinedAt == resource.data.joinedAt;
    }

    function safeManagerMembershipSync(clubId, teamId) {
      return isManager(clubId, teamId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.clubSlug == resource.data.clubSlug
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.teamSlug == resource.data.teamSlug
        && request.resource.data.playerId == resource.data.playerId
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.joinedAt == resource.data.joinedAt;
    }

    function safeCaptainRoleUpdate(clubId, teamId) {
      return isCaptain(clubId, teamId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.clubSlug == resource.data.clubSlug
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.teamSlug == resource.data.teamSlug
        && request.resource.data.playerId == resource.data.playerId
        && request.resource.data.teamName == resource.data.teamName
        && request.resource.data.status == resource.data.status
        && request.resource.data.joinedAt == resource.data.joinedAt
        && resource.data.role in ['member', 'coCaptain']
        && request.resource.data.role in ['member', 'coCaptain'];
    }

    function userProfileKeys() {
      return [
        'displayName',
        'email',
        'firstName',
        'fullName',
        'headshotPath',
        'headshotUrl',
        'lastActiveClubId',
        'lastActiveTeamId',
        'lastName',
        'lastSeenAt',
        'photoURL',
        'skillLevel',
        'uid',
        'updatedAt',
      ];
    }

    function safeSelfUserProfileCreate(uid) {
      return isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.keys().hasOnly(userProfileKeys());
    }

    function safeSelfUserProfileUpdate(uid) {
      return isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(userProfileKeys());
    }

    function eventKeys() {
      return [
        'bulletPoints',
        'costLabel',
        'createdAt',
        'createdBy',
        'description',
        'detailsHeading',
        'endDate',
        'eventType',
        'flyerImagePath',
        'flyerImageUrl',
        'locationLabel',
        'registrationInfo',
        'registrationUrl',
        'startDate',
        'status',
        'timeLabel',
        'title',
        'updatedAt',
        'updatedBy',
      ];
    }

    function safeClubEventWrite(clubId) {
      return isClubApprover(clubId)
        && request.resource.data.keys().hasOnly(eventKeys())
        && request.resource.data.title is string
        && request.resource.data.description is string
        && request.resource.data.detailsHeading is string
        && request.resource.data.bulletPoints is list
        && request.resource.data.registrationInfo is string
        && request.resource.data.registrationUrl is string
        && request.resource.data.costLabel is string
        && request.resource.data.startDate is string
        && request.resource.data.endDate is string
        && request.resource.data.timeLabel is string
        && request.resource.data.locationLabel is string
        && request.resource.data.eventType in ['singleDay', 'multiDay', 'boxLeague']
        && request.resource.data.status in ['draft', 'published', 'archived']
        && request.resource.data.flyerImagePath is string
        && request.resource.data.flyerImageUrl is string
        && request.resource.data.updatedBy == request.auth.uid;
    }

    function safeSelfPlayerWrite(playerId, teamId) {
      return isSelf(playerId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.teamId == teamId;
    }

    function safeSelfPlayerProfileUpdate(playerId, clubId, teamId) {
      return isTeamMember(clubId, teamId)
        && memberDoc(clubId, teamId).data.playerId == playerId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'availableDays',
          'notes',
          'updatedAt',
        ]);
    }

    function safeSelfPlayerSnapshotSync(playerId, clubId, teamId) {
      return isTeamMember(clubId, teamId)
        && memberDoc(clubId, teamId).data.playerId == playerId
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'displayName',
          'email',
          'firstName',
          'fullName',
          'headshotPath',
          'headshotUrl',
          'lastName',
          'skillLevel',
          'updatedAt',
        ])
        && request.resource.data.displayName == userProfileDoc(request.auth.uid).data.displayName
        && request.resource.data.email == userProfileDoc(request.auth.uid).data.email
        && request.resource.data.firstName == userProfileDoc(request.auth.uid).data.firstName
        && request.resource.data.fullName == userProfileDoc(request.auth.uid).data.fullName
        && request.resource.data.headshotPath == userProfileDoc(request.auth.uid).data.headshotPath
        && request.resource.data.headshotUrl == userProfileDoc(request.auth.uid).data.headshotUrl
        && request.resource.data.lastName == userProfileDoc(request.auth.uid).data.lastName
        && request.resource.data.skillLevel == userProfileDoc(request.auth.uid).data.skillLevel;
    }

    function safeManagerPlayerTeamUpdate(clubId, teamId) {
      return isManager(clubId, teamId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'active',
          'notes',
          'updatedAt',
        ]);
    }

    function safeSelfPlayerDelete(playerId, clubId, teamId) {
      return isTeamMember(clubId, teamId)
        && memberDoc(clubId, teamId).data.playerId == playerId
        && resource.data.uid == request.auth.uid;
    }

    function safeSelfPlayerLinkWrite(uid, teamId) {
      return isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.teamId == teamId
        && request.resource.data.playerId == uid;
    }

    function safeSelfRosterRemoval(clubId, teamId) {
      let playerId = memberDoc(clubId, teamId).data.playerId;
      return isTeamMember(clubId, teamId)
        && playerId is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'attendance',
          'pairings',
          'rosterPlayerIds',
          'updatedAt',
        ])
        && !request.resource.data.attendance.keys().hasAny([playerId])
        && !request.resource.data.rosterPlayerIds.hasAny([playerId]);
    }

    function safeManagerMembershipSummaryDelete(uid) {
      return signedIn()
        && resource.data.clubSlug is string
        && resource.data.teamSlug is string
        && resource.data.uid == uid
        && isManager(resource.data.clubSlug, resource.data.teamSlug);
    }

    function safeSelfAvailabilityUpdate(clubId, teamId) {
      let playerId = memberDoc(clubId, teamId).data.playerId;
      return isTeamMember(clubId, teamId)
        && playerId is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'attendance',
          'updatedAt',
        ])
        && request.resource.data.attendance.diff(resource.data.attendance).affectedKeys().hasOnly([playerId])
        && (
          !request.resource.data.attendance.keys().hasAny([playerId])
          || request.resource.data.attendance[playerId] in ['in', 'out']
        );
    }

    function teamDoc(teamClubId, teamId) {
      return get(/databases/$(database)/documents/clubs/$(teamClubId)/teams/$(teamId));
    }

    function isApprovedChallengeClubTeam(challengeClubId, teamClubId, teamId) {
      return teamDoc(teamClubId, teamId).data.affiliationStatus == 'approved'
        && teamDoc(teamClubId, teamId).data.status == 'active'
        && teamDoc(teamClubId, teamId).data.approvedClubSlug == challengeClubId;
    }

    function challengeAfter(challengeClubId, challengeId) {
      return getAfter(/databases/$(database)/documents/clubs/$(challengeClubId)/challenges/$(challengeId));
    }

    function safeChallengeCreate(clubId) {
      return signedIn()
        && request.resource.data.status == 'open'
        && request.resource.data.clubSlug == clubId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.playersNeeded in [1, 2]
        && validChallengeCreatePlayerChoices()
        && request.resource.data.visibility in ['open', 'targeted']
        && request.resource.data.createdByTeamClubSlug is string
        && request.resource.data.createdByTeamSlug is string
        && isManager(request.resource.data.createdByTeamClubSlug, request.resource.data.createdByTeamSlug)
        && isApprovedChallengeClubTeam(clubId, request.resource.data.createdByTeamClubSlug, request.resource.data.createdByTeamSlug)
        && (
          request.resource.data.visibility == 'open'
          || (
            request.resource.data.targetTeamClubSlug is string
            && request.resource.data.targetTeamSlug is string
            && isApprovedChallengeClubTeam(clubId, request.resource.data.targetTeamClubSlug, request.resource.data.targetTeamSlug)
            && !(
              request.resource.data.targetTeamClubSlug == request.resource.data.createdByTeamClubSlug
              && request.resource.data.targetTeamSlug == request.resource.data.createdByTeamSlug
            )
          )
        );
    }

    function emptyChallengePlayerChoice(fieldId, fieldName) {
      return request.resource.data[fieldId] == ''
        && request.resource.data[fieldName] == '';
    }

    function validSinglesChallengePlayerChoice(fieldId, fieldName) {
      return request.resource.data[fieldId] is string
        && request.resource.data[fieldId] != ''
        && request.resource.data[fieldName] is string
        && request.resource.data[fieldName] != '';
    }

    function validChallengeCreatePlayerChoices() {
      return (
          request.resource.data.playersNeeded == 1
          && validSinglesChallengePlayerChoice('createdByPlayerId', 'createdByPlayerName')
          && emptyChallengePlayerChoice('acceptedByPlayerId', 'acceptedByPlayerName')
        )
        || (
          request.resource.data.playersNeeded == 2
          && emptyChallengePlayerChoice('createdByPlayerId', 'createdByPlayerName')
          && emptyChallengePlayerChoice('acceptedByPlayerId', 'acceptedByPlayerName')
        );
    }

    function validChallengeEditPlayerChoices() {
      return (
          request.resource.data.playersNeeded == 1
          && validSinglesChallengePlayerChoice('createdByPlayerId', 'createdByPlayerName')
          && request.resource.data.acceptedByPlayerId == resource.data.acceptedByPlayerId
          && request.resource.data.acceptedByPlayerName == resource.data.acceptedByPlayerName
        )
        || (
          request.resource.data.playersNeeded == 2
          && emptyChallengePlayerChoice('createdByPlayerId', 'createdByPlayerName')
          && request.resource.data.acceptedByPlayerId == resource.data.acceptedByPlayerId
          && request.resource.data.acceptedByPlayerName == resource.data.acceptedByPlayerName
        );
    }

    function validChallengeAcceptPlayerChoices() {
      return (
          resource.data.playersNeeded == 1
          && request.resource.data.createdByPlayerId == resource.data.createdByPlayerId
          && request.resource.data.createdByPlayerName == resource.data.createdByPlayerName
          && validSinglesChallengePlayerChoice('acceptedByPlayerId', 'acceptedByPlayerName')
        )
        || (
          resource.data.playersNeeded == 2
          && request.resource.data.createdByPlayerId == resource.data.createdByPlayerId
          && request.resource.data.createdByPlayerName == resource.data.createdByPlayerName
          && emptyChallengePlayerChoice('acceptedByPlayerId', 'acceptedByPlayerName')
        );
    }

    function safeChallengeCancel() {
      return resource.data.status == 'open'
        && isManager(resource.data.createdByTeamClubSlug, resource.data.createdByTeamSlug)
        && request.resource.data.status == 'cancelled'
        && request.resource.data.createdByTeamClubSlug == resource.data.createdByTeamClubSlug
        && request.resource.data.createdByTeamSlug == resource.data.createdByTeamSlug
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'cancelledAt',
          'status',
          'updatedAt',
        ]);
    }

    function safeAcceptedChallengeMatchCancel() {
      return resource.data.status == 'accepted'
        && request.resource.data.status == 'cancelled'
        && (
          isManager(resource.data.createdByTeamClubSlug, resource.data.createdByTeamSlug)
          || isManager(resource.data.acceptedByTeamClubSlug, resource.data.acceptedByTeamSlug)
        )
        && request.resource.data.homeGameId == ''
        && request.resource.data.awayGameId == ''
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'awayGameId',
          'cancelledAt',
          'homeGameId',
          'status',
          'updatedAt',
        ]);
    }

    function safeChallengeEdit(clubId) {
      return resource.data.status == 'open'
        && request.resource.data.status == 'open'
        && isManager(resource.data.createdByTeamClubSlug, resource.data.createdByTeamSlug)
        && isApprovedChallengeClubTeam(clubId, resource.data.createdByTeamClubSlug, resource.data.createdByTeamSlug)
        && request.resource.data.createdByTeamClubSlug == resource.data.createdByTeamClubSlug
        && request.resource.data.createdByTeamSlug == resource.data.createdByTeamSlug
        && request.resource.data.createdByUid == resource.data.createdByUid
        && request.resource.data.clubSlug == resource.data.clubSlug
        && request.resource.data.playersNeeded in [1, 2]
        && validChallengeEditPlayerChoices()
        && request.resource.data.visibility in ['open', 'targeted']
        && (
          request.resource.data.visibility == 'open'
          || (
            request.resource.data.targetTeamClubSlug is string
            && request.resource.data.targetTeamSlug is string
            && isApprovedChallengeClubTeam(clubId, request.resource.data.targetTeamClubSlug, request.resource.data.targetTeamSlug)
            && !(
              request.resource.data.targetTeamClubSlug == resource.data.createdByTeamClubSlug
              && request.resource.data.targetTeamSlug == resource.data.createdByTeamSlug
            )
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'dateTbd',
          'createdByPlayerId',
          'createdByPlayerName',
          'isoDate',
          'location',
          'playersNeeded',
          'targetTeamClubSlug',
          'targetTeamName',
          'targetTeamSlug',
          'timeLabel',
          'updatedAt',
          'visibility',
        ]);
    }

    function safeChallengeDecline() {
      return resource.data.status == 'open'
        && resource.data.visibility == 'targeted'
        && isManager(resource.data.targetTeamClubSlug, resource.data.targetTeamSlug)
        && request.resource.data.status == 'declined'
        && request.resource.data.targetTeamClubSlug == resource.data.targetTeamClubSlug
        && request.resource.data.targetTeamSlug == resource.data.targetTeamSlug
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'declinedAt',
          'status',
          'updatedAt',
        ]);
    }

    function safeChallengeAccept(clubId) {
      return resource.data.status == 'open'
        && request.resource.data.status == 'accepted'
        && request.resource.data.acceptedByUid == request.auth.uid
        && request.resource.data.acceptedByTeamClubSlug is string
        && request.resource.data.acceptedByTeamSlug is string
        && validChallengeAcceptPlayerChoices()
        && isManager(request.resource.data.acceptedByTeamClubSlug, request.resource.data.acceptedByTeamSlug)
        && isApprovedChallengeClubTeam(clubId, resource.data.createdByTeamClubSlug, resource.data.createdByTeamSlug)
        && isApprovedChallengeClubTeam(clubId, request.resource.data.acceptedByTeamClubSlug, request.resource.data.acceptedByTeamSlug)
        && request.resource.data.createdByTeamClubSlug == resource.data.createdByTeamClubSlug
        && request.resource.data.createdByTeamSlug == resource.data.createdByTeamSlug
        && !(
          request.resource.data.acceptedByTeamClubSlug == resource.data.createdByTeamClubSlug
          && request.resource.data.acceptedByTeamSlug == resource.data.createdByTeamSlug
        )
        && (
          resource.data.visibility == 'open'
          || (
            request.resource.data.acceptedByTeamClubSlug == resource.data.targetTeamClubSlug
            && request.resource.data.acceptedByTeamSlug == resource.data.targetTeamSlug
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'acceptedAt',
          'acceptedByPlayerId',
          'acceptedByPlayerName',
          'acceptedByTeamClubSlug',
          'acceptedByTeamName',
          'acceptedByTeamSlug',
          'acceptedByUid',
          'awayGameId',
          'homeGameId',
          'status',
          'updatedAt',
        ]);
    }

    function safeChallengeGameCreate(clubId, teamId) {
      let challenge = challengeAfter(request.resource.data.challengeClubSlug, request.resource.data.challengeId).data;
      return signedIn()
        && request.resource.data.challengeClubSlug is string
        && request.resource.data.challengeId is string
        && (
          request.resource.data.playersNeeded == challenge.playersNeeded
          || (!challenge.keys().hasAny(['playersNeeded']) && request.resource.data.playersNeeded == 2)
        )
        && validChallengeGameRoster(request.resource.data.playersNeeded)
        && challenge.status == 'accepted'
        && challenge.acceptedByUid == request.auth.uid
        && (
          (
            clubId == challenge.createdByTeamClubSlug
            && teamId == challenge.createdByTeamSlug
            && request.resource.data.linkedGameId == challenge.awayGameId
          )
          || (
            clubId == challenge.acceptedByTeamClubSlug
            && teamId == challenge.acceptedByTeamSlug
            && request.resource.data.linkedGameId == challenge.homeGameId
          )
        );
    }

    function validChallengeGameRoster(playersNeeded) {
      return request.resource.data.rosterPlayerIds is list
        && request.resource.data.pairings is list
        && request.resource.data.pairings.size() == 1
        && request.resource.data.pairings[0].playerIds is list
        && request.resource.data.rosterPlayerIds.size() == playersNeeded
        && request.resource.data.pairings[0].playerIds.size() == playersNeeded
        && playersNeeded in [1, 2];
    }

    function safeLinkedManualGameCreate(clubId, teamId) {
      return signedIn()
        && request.resource.data.source == 'manual'
        && request.resource.data.linkedTeamClubSlug is string
        && request.resource.data.linkedTeamSlug is string
        && request.resource.data.linkedGameId is string
        && request.resource.data.playersNeeded in [1, 2]
        && !(request.resource.data.linkedTeamClubSlug == clubId && request.resource.data.linkedTeamSlug == teamId)
        && isManager(request.resource.data.linkedTeamClubSlug, request.resource.data.linkedTeamSlug);
    }

    function safeLinkedGameMirrorDelete() {
      return signedIn()
        && resource.data.linkedTeamClubSlug is string
        && resource.data.linkedTeamSlug is string
        && resource.data.linkedGameId is string
        && (!resource.data.keys().hasAny(['source']) || resource.data.source in ['manual', 'challenge'])
        && isManager(resource.data.linkedTeamClubSlug, resource.data.linkedTeamSlug);
    }

    function safeLinkedGameUpdate(clubId, teamId) {
      return signedIn()
        && resource.data.linkedTeamClubSlug is string
        && resource.data.linkedTeamSlug is string
        && resource.data.linkedGameId is string
        && request.resource.data.linkedTeamClubSlug == resource.data.linkedTeamClubSlug
        && request.resource.data.linkedTeamSlug == resource.data.linkedTeamSlug
        && request.resource.data.linkedGameId == resource.data.linkedGameId
        && request.resource.data.source == resource.data.source
        && request.resource.data.playersNeeded in [1, 2]
        && !(resource.data.linkedTeamClubSlug == clubId && resource.data.linkedTeamSlug == teamId)
        && isManager(resource.data.linkedTeamClubSlug, resource.data.linkedTeamSlug);
    }

    match /adminNotifications/{notificationId} {
      allow read, delete: if isPlatformAdmin();
      allow create: if safeAdminNotificationCreate();
      allow update: if false;
    }

    match /activityLogs/{logId} {
      allow read: if canReadActivityLog();
      allow delete: if isPlatformAdmin();
      allow create: if safeActivityLogCreate();
      allow update: if false;
    }

    match /users/{uid} {
      allow read: if isSelf(uid) || isPlatformAdmin();
      allow create: if safeSelfUserProfileCreate(uid);
      allow update: if safeSelfUserProfileUpdate(uid);

      match /memberships/{membershipId} {
        allow read: if isSelf(uid);
        allow create, update: if isSelf(uid) || isPlatformAdmin();
        allow delete: if isSelf(uid) || isPlatformAdmin() || safeManagerMembershipSummaryDelete(uid);
      }
    }

    match /platformAdmins/{uid} {
      allow read: if isSelf(uid) || isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    match /{path=**}/teams/{teamId} {
      allow read: if signedIn();
    }

    match /clubs/{clubId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.slug == clubId
        && request.resource.data.status == 'active'
        && (isReservedClubCreate(clubId) || isPlatformAdmin());
      allow update: if isPlatformAdmin()
        && request.resource.data.slug == resource.data.slug;
      allow delete: if isPlatformAdmin() && clubId != 'independent';

      match /admins/{uid} {
        allow read: if signedIn();
        allow write: if isPlatformAdmin();
      }

      match /events/{eventId} {
        allow read: if signedIn()
          && (resource.data.status == 'published' || isClubApprover(clubId));
        allow create: if safeClubEventWrite(clubId)
          && request.resource.data.createdBy == request.auth.uid;
        allow update: if safeClubEventWrite(clubId)
          && request.resource.data.createdBy == resource.data.createdBy;
        allow delete: if isClubApprover(clubId) || isPlatformAdmin();
      }

      match /affiliationRequests/{requestId} {
        allow read: if isClubApprover(clubId)
          || isManager(resource.data.teamClubSlug, resource.data.teamSlug);
        allow create: if signedIn()
          && request.resource.data.requestedClubSlug == clubId
          && request.resource.data.clubSlug == clubId
          && request.resource.data.status == 'pending'
          && request.resource.data.teamClubSlug is string
          && request.resource.data.teamSlug is string
          && isManager(request.resource.data.teamClubSlug, request.resource.data.teamSlug);
        allow update: if isClubApprover(clubId)
          && request.resource.data.teamClubSlug == resource.data.teamClubSlug
          && request.resource.data.teamSlug == resource.data.teamSlug
          && request.resource.data.requestedClubSlug == resource.data.requestedClubSlug
          && request.resource.data.clubSlug == resource.data.clubSlug
          && request.resource.data.status in ['approved', 'rejected']
          && request.resource.data.reviewedBy == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'reviewedAt',
            'reviewedBy',
            'status',
            'updatedAt',
          ]);
        allow delete: if isPlatformAdmin();
      }

      match /challenges/{challengeId} {
        allow read: if signedIn();
        allow create: if safeChallengeCreate(clubId);
        allow update: if safeChallengeAccept(clubId)
          || safeChallengeEdit(clubId)
          || safeChallengeDecline()
          || safeChallengeCancel()
          || safeAcceptedChallengeMatchCancel();
        allow delete: if isPlatformAdmin();
      }

      match /newsPosts/{postId} {
        allow read: if hasActiveTeamInClub(clubId) || isPlatformAdmin();
        allow create: if request.resource.data.teamSlug is string
          && isTeamMember(clubId, request.resource.data.teamSlug)
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.createdByUid == request.auth.uid;
        allow update: if isPlatformAdmin()
          || (
            hasActiveTeamInClub(clubId)
            && resource.data.authorUid == request.auth.uid
            && request.resource.data.authorUid == resource.data.authorUid
            && request.resource.data.createdByUid == resource.data.createdByUid
            && request.resource.data.teamSlug == resource.data.teamSlug
          );
        allow delete: if isPlatformAdmin()
          || (
            hasActiveTeamInClub(clubId)
            && resource.data.authorUid == request.auth.uid
          );

        match /comments/{commentId} {
          allow read: if hasActiveTeamInClub(clubId) || isPlatformAdmin();
          allow create: if hasActiveTeamInClub(clubId)
            && request.resource.data.authorUid == request.auth.uid
            && request.resource.data.createdBy == request.auth.uid;
          allow update: if hasActiveTeamInClub(clubId)
            && (resource.data.authorUid == request.auth.uid || resource.data.createdBy == request.auth.uid)
            && request.resource.data.updatedBy == request.auth.uid
            && request.resource.data.body is string
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'body',
              'updatedAt',
              'updatedBy',
            ]);
          allow delete: if isPlatformAdmin()
            || (
              hasActiveTeamInClub(clubId)
              && resource.data.authorUid == request.auth.uid
            );
        }

        match /reactions/{uid} {
          allow read: if hasActiveTeamInClub(clubId) || isPlatformAdmin();
          allow create, update: if isSelf(uid)
            && hasActiveTeamInClub(clubId)
            && request.resource.data.uid == uid
            && request.resource.data.type in ['like', 'love', 'thumbsUp', 'thumbsDown', 'laugh', 'cry', 'angry'];
          allow delete: if isSelf(uid)
            || isPlatformAdmin();
        }
      }

      match /teams/{teamId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.clubId == clubId
          && request.resource.data.slug == teamId
          && request.resource.data.status == 'active';
        allow update: if safeTeamMemberCountIncrement(clubId, teamId)
          || safeTeamMemberCountDecrement(clubId, teamId)
          || (
            isManager(clubId, teamId)
            && request.resource.data.clubId == resource.data.clubId
            && request.resource.data.slug == resource.data.slug
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.status == resource.data.status
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'affiliationStatus',
              'joinCode',
              'logoPath',
              'logoUrl',
              'memberCount',
              'name',
              'publicSlug',
              'requestedClubName',
              'requestedClubSlug',
              'status',
              'updatedAt',
            ])
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                'affiliationStatus',
                'requestedClubName',
                'requestedClubSlug',
              ])
              || request.resource.data.affiliationStatus == 'pending'
            )
          )
          || (
            isManager(clubId, teamId)
            && resource.data.status == 'active'
            && request.resource.data.status == 'archived'
            && request.resource.data.clubId == resource.data.clubId
            && request.resource.data.slug == resource.data.slug
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.joinCode == ''
            && request.resource.data.archivedBy == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'archivedAt',
              'archivedBy',
              'joinCode',
              'status',
              'updatedAt',
            ])
          )
          || (
            isClubApprover(resource.data.requestedClubSlug)
            && request.resource.data.clubId == resource.data.clubId
            && request.resource.data.slug == resource.data.slug
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.affiliationStatus in ['approved', 'rejected']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'affiliationStatus',
              'approvedAt',
              'approvedBy',
              'approvedClubSlug',
              'requestedClubSlug',
              'updatedAt',
            ])
          )
          || (
            isPlatformAdmin()
            && request.resource.data.clubId == resource.data.clubId
            && request.resource.data.slug == resource.data.slug
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'logoPath',
              'logoUrl',
              'memberCount',
              'updatedAt',
            ])
          );
        allow delete: if isPlatformAdmin();

        match /members/{uid} {
          allow read: if isSelf(uid) || isTeamMember(clubId, teamId) || isAdminContext() || hasActiveApprovedTeamInClub(clubId);
          allow create: if isPlatformAdmin()
            || (
              signedIn()
              && request.auth.uid == uid
              && request.resource.data.uid == uid
              && request.resource.data.clubId == clubId
              && request.resource.data.teamId == teamId
              && request.resource.data.teamSlug == teamId
              && (
                !get(/databases/$(database)/documents/clubs/$(clubId)/teams/$(teamId)).data.keys().hasAny(['memberCount'])
                || get(/databases/$(database)/documents/clubs/$(clubId)/teams/$(teamId)).data.memberCount < 2
              )
              && request.resource.data.role in ['captain', 'member']
              && request.resource.data.status == 'active'
            );
          allow update: if safeSelfMembershipUpdate(uid)
            || safeManagerMembershipSync(clubId, teamId)
            || safeCaptainRoleUpdate(clubId, teamId)
            || isPlatformAdmin();
          allow delete: if isSelf(uid) || isManager(clubId, teamId) || isPlatformAdmin();
        }

        match /players/{playerId} {
          allow read: if isTeamMember(clubId, teamId) || isAdminContext() || hasActiveApprovedTeamInClub(clubId);
          allow create: if safeSelfPlayerWrite(playerId, teamId) || isPlatformAdmin();
          allow update: if safeManagerPlayerTeamUpdate(clubId, teamId)
            || safeSelfPlayerProfileUpdate(playerId, clubId, teamId)
            || safeSelfPlayerSnapshotSync(playerId, clubId, teamId)
            || isPlatformAdmin();
          allow delete: if isManager(clubId, teamId) || safeSelfPlayerDelete(playerId, clubId, teamId) || isPlatformAdmin();
        }

        match /playerLinks/{uid} {
          allow read: if isSelf(uid) || isManager(clubId, teamId) || isPlatformAdmin();
          allow create, update: if safeSelfPlayerLinkWrite(uid, teamId) || isManager(clubId, teamId) || isPlatformAdmin();
          allow delete: if isSelf(uid) || isManager(clubId, teamId) || isPlatformAdmin();
        }

        match /games/{gameId} {
          allow read: if isTeamMember(clubId, teamId) || isPlatformAdmin() || isApprovedClubTeam(clubId, teamId);
          allow create: if (isManager(clubId, teamId) && request.resource.data.playersNeeded in [1, 2])
            || safeChallengeGameCreate(clubId, teamId)
            || safeLinkedManualGameCreate(clubId, teamId);
          allow update: if (isManager(clubId, teamId) && request.resource.data.playersNeeded in [1, 2])
            || isPlatformAdmin()
            || safeLinkedGameUpdate(clubId, teamId)
            || safeSelfAvailabilityUpdate(clubId, teamId)
            || safeSelfRosterRemoval(clubId, teamId);
          allow delete: if isPlatformAdmin() || isManager(clubId, teamId) || safeLinkedGameMirrorDelete();
        }

        match /newsPosts/{postId} {
          allow read: if isTeamMember(clubId, teamId) || isPlatformAdmin();
          allow create: if isTeamMember(clubId, teamId)
            && request.resource.data.authorUid == request.auth.uid
            && request.resource.data.createdByUid == request.auth.uid;
          allow update: if isPlatformAdmin()
            || (
              isTeamMember(clubId, teamId)
              && resource.data.authorUid == request.auth.uid
              && request.resource.data.authorUid == resource.data.authorUid
              && request.resource.data.createdByUid == resource.data.createdByUid
            );
          allow delete: if isPlatformAdmin()
            || (
              isTeamMember(clubId, teamId)
              && resource.data.authorUid == request.auth.uid
            );

          match /comments/{commentId} {
            allow read: if isTeamMember(clubId, teamId) || isPlatformAdmin();
            allow create: if isTeamMember(clubId, teamId)
              && request.resource.data.authorUid == request.auth.uid
              && request.resource.data.createdBy == request.auth.uid;
            allow update: if isTeamMember(clubId, teamId)
              && (resource.data.authorUid == request.auth.uid || resource.data.createdBy == request.auth.uid)
              && request.resource.data.updatedBy == request.auth.uid
              && request.resource.data.body is string
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                'body',
                'updatedAt',
                'updatedBy',
              ]);
            allow delete: if isPlatformAdmin()
              || (
                isTeamMember(clubId, teamId)
                && resource.data.authorUid == request.auth.uid
              );
          }

          match /reactions/{uid} {
            allow read: if isTeamMember(clubId, teamId) || isPlatformAdmin();
            allow create, update: if isSelf(uid)
              && isTeamMember(clubId, teamId)
              && request.resource.data.uid == uid
              && request.resource.data.type in ['like', 'love', 'thumbsUp', 'thumbsDown', 'laugh', 'cry', 'angry'];
            allow delete: if isSelf(uid) || isPlatformAdmin();
          }
        }
      }
    }
  }
}
