rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function memberPath(clubId, teamId) {
      return /databases/$(database)/documents/clubs/$(clubId)/teams/$(teamId)/members/$(request.auth.uid);
    }

    function memberDoc(clubId, teamId) {
      return get(memberPath(clubId, teamId));
    }

    function isTeamMember(clubId, teamId) {
      return signedIn() && exists(memberPath(clubId, teamId));
    }

    function hasTeamRole(clubId, teamId, roles) {
      return isTeamMember(clubId, teamId) && memberDoc(clubId, teamId).data.role in roles;
    }

    function isManager(clubId, teamId) {
      return hasTeamRole(clubId, teamId, ['captain', 'coCaptain']);
    }

    function isCaptain(clubId, teamId) {
      return hasTeamRole(clubId, teamId, ['captain']);
    }

    function safeSelfMembershipUpdate(uid) {
      return isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.clubSlug == resource.data.clubSlug
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.teamSlug == resource.data.teamSlug
        && request.resource.data.teamName == resource.data.teamName
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.joinedAt == resource.data.joinedAt;
    }

    function safeManagerMembershipSync(uid, clubId, teamId) {
      return isManager(clubId, teamId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.clubSlug == resource.data.clubSlug
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.teamSlug == resource.data.teamSlug
        && request.resource.data.playerId == resource.data.playerId
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.joinedAt == resource.data.joinedAt;
    }

    function safeCaptainRoleUpdate(uid, clubId, teamId) {
      return isCaptain(clubId, teamId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.clubSlug == resource.data.clubSlug
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.teamSlug == resource.data.teamSlug
        && request.resource.data.playerId == resource.data.playerId
        && request.resource.data.teamName == resource.data.teamName
        && request.resource.data.status == resource.data.status
        && request.resource.data.joinedAt == resource.data.joinedAt
        && resource.data.role in ['member', 'coCaptain']
        && request.resource.data.role in ['member', 'coCaptain'];
    }

    function safeSelfPlayerWrite(playerId, teamId) {
      return isSelf(playerId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.teamId == teamId;
    }

    function safeSelfPlayerLinkWrite(uid, teamId) {
      return isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.teamId == teamId
        && request.resource.data.playerId == uid;
    }

    match /users/{uid} {
      allow read, create: if isSelf(uid);
      allow update: if isSelf(uid) && request.resource.data.uid == resource.data.uid;

      match /memberships/{membershipId} {
        allow read, create, update: if isSelf(uid);
      }
    }

    match /clubs/{clubId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.slug == clubId
        && request.resource.data.status == 'active';
      allow update: if false;

      match /admins/{uid} {
        allow read: if signedIn();
        allow write: if false;
      }

      match /teams/{teamId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.clubId == clubId
          && request.resource.data.slug == teamId
          && request.resource.data.status == 'active';
        allow update: if isManager(clubId, teamId)
          && request.resource.data.clubId == resource.data.clubId
          && request.resource.data.slug == resource.data.slug
          && request.resource.data.createdBy == resource.data.createdBy;

        match /members/{uid} {
          allow read: if isTeamMember(clubId, teamId);
          allow create: if signedIn()
            && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.clubId == clubId
            && request.resource.data.teamId == teamId
            && request.resource.data.teamSlug == teamId
            && request.resource.data.role in ['captain', 'member']
            && request.resource.data.status == 'active';
          allow update: if safeSelfMembershipUpdate(uid)
            || safeManagerMembershipSync(uid, clubId, teamId)
            || safeCaptainRoleUpdate(uid, clubId, teamId);
        }

        match /players/{playerId} {
          allow read: if isTeamMember(clubId, teamId);
          allow create, update: if isManager(clubId, teamId) || safeSelfPlayerWrite(playerId, teamId);
        }

        match /playerLinks/{uid} {
          allow read: if isSelf(uid) || isManager(clubId, teamId);
          allow create, update: if safeSelfPlayerLinkWrite(uid, teamId) || isManager(clubId, teamId);
        }

        match /games/{gameId} {
          allow read: if isTeamMember(clubId, teamId);
          allow create, update, delete: if isManager(clubId, teamId);
        }

        match /newsPosts/{postId} {
          allow read: if isTeamMember(clubId, teamId);
          allow create, update, delete: if isManager(clubId, teamId);
        }
      }
    }
  }
}
