rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function memberPath(clubId, teamId) {
      return /databases/$(database)/documents/clubs/$(clubId)/teams/$(teamId)/members/$(request.auth.uid);
    }

    function memberDoc(clubId, teamId) {
      return get(memberPath(clubId, teamId));
    }

    function isTeamMember(clubId, teamId) {
      return signedIn() && exists(memberPath(clubId, teamId));
    }

    function hasTeamRole(clubId, teamId, roles) {
      return isTeamMember(clubId, teamId) && memberDoc(clubId, teamId).data.role in roles;
    }

    function isManager(clubId, teamId) {
      return hasTeamRole(clubId, teamId, ['captain', 'coCaptain']);
    }

    function isCaptain(clubId, teamId) {
      return hasTeamRole(clubId, teamId, ['captain']);
    }

    function isBootstrapPlatformAdmin() {
      return signedIn()
        && request.auth.token.email in ['demandgendave@gmail.com'];
    }

    function isPlatformAdmin() {
      return isBootstrapPlatformAdmin();
    }

    function isClubAdmin(clubId) {
      return signedIn()
        && exists(/databases/$(database)/documents/clubs/$(clubId)/admins/$(request.auth.uid));
    }

    function isClubApprover(clubId) {
      return isPlatformAdmin() || isClubAdmin(clubId);
    }

    function isAdminContext() {
      return isPlatformAdmin();
    }

    function isReservedClubCreate(clubId) {
      return clubId in ['independent'];
    }

    function safeSelfMembershipUpdate(uid) {
      return isSelf(uid)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.clubSlug == resource.data.clubSlug
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.teamSlug == resource.data.teamSlug
        && request.resource.data.teamName == resource.data.teamName
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.joinedAt == resource.data.joinedAt;
    }

    function safeManagerMembershipSync(uid, clubId, teamId) {
      return isManager(clubId, teamId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.clubSlug == resource.data.clubSlug
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.teamSlug == resource.data.teamSlug
        && request.resource.data.playerId == resource.data.playerId
        && request.resource.data.role == resource.data.role
        && request.resource.data.status == resource.data.status
        && request.resource.data.joinedAt == resource.data.joinedAt;
    }

    function safeCaptainRoleUpdate(uid, clubId, teamId) {
      return isCaptain(clubId, teamId)
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.clubId == resource.data.clubId
        && request.resource.data.clubSlug == resource.data.clubSlug
        && request.resource.data.teamId == resource.data.teamId
        && request.resource.data.teamSlug == resource.data.teamSlug
        && request.resource.data.playerId == resource.data.playerId
        && request.resource.data.teamName == resource.data.teamName
        && request.resource.data.status == resource.data.status
        && request.resource.data.joinedAt == resource.data.joinedAt
        && resource.data.role in ['member', 'coCaptain']
        && request.resource.data.role in ['member', 'coCaptain'];
    }

    function safeSelfPlayerWrite(playerId, teamId) {
      return isSelf(playerId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.teamId == teamId;
    }

    function safeSelfPlayerLinkWrite(uid, teamId) {
      return isSelf(uid)
        && request.resource.data.uid == uid
        && request.resource.data.teamId == teamId
        && request.resource.data.playerId == uid;
    }

    function safeSelfAvailabilityUpdate(clubId, teamId) {
      let playerId = memberDoc(clubId, teamId).data.playerId;
      return isTeamMember(clubId, teamId)
        && playerId is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'attendance',
          'updatedAt',
        ])
        && request.resource.data.attendance.diff(resource.data.attendance).affectedKeys().hasOnly([playerId])
        && (
          !request.resource.data.attendance.keys().hasAny([playerId])
          || request.resource.data.attendance[playerId] in ['in', 'out']
        );
    }

    function teamDoc(teamClubId, teamId) {
      return get(/databases/$(database)/documents/clubs/$(teamClubId)/teams/$(teamId));
    }

    function isApprovedClubTeam(challengeClubId, teamClubId, teamId) {
      return teamDoc(teamClubId, teamId).data.affiliationStatus == 'approved'
        && teamDoc(teamClubId, teamId).data.approvedClubSlug == challengeClubId;
    }

    function challengeAfter(challengeClubId, challengeId) {
      return getAfter(/databases/$(database)/documents/clubs/$(challengeClubId)/challenges/$(challengeId));
    }

    function safeChallengeCreate(clubId) {
      return signedIn()
        && request.resource.data.status == 'open'
        && request.resource.data.clubSlug == clubId
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.visibility in ['open', 'targeted']
        && request.resource.data.createdByTeamClubSlug is string
        && request.resource.data.createdByTeamSlug is string
        && isManager(request.resource.data.createdByTeamClubSlug, request.resource.data.createdByTeamSlug)
        && isApprovedClubTeam(clubId, request.resource.data.createdByTeamClubSlug, request.resource.data.createdByTeamSlug)
        && (
          request.resource.data.visibility == 'open'
          || (
            request.resource.data.targetTeamClubSlug is string
            && request.resource.data.targetTeamSlug is string
            && isApprovedClubTeam(clubId, request.resource.data.targetTeamClubSlug, request.resource.data.targetTeamSlug)
            && !(
              request.resource.data.targetTeamClubSlug == request.resource.data.createdByTeamClubSlug
              && request.resource.data.targetTeamSlug == request.resource.data.createdByTeamSlug
            )
          )
        );
    }

    function safeChallengeCancel() {
      return resource.data.status == 'open'
        && isManager(resource.data.createdByTeamClubSlug, resource.data.createdByTeamSlug)
        && request.resource.data.status == 'cancelled'
        && request.resource.data.createdByTeamClubSlug == resource.data.createdByTeamClubSlug
        && request.resource.data.createdByTeamSlug == resource.data.createdByTeamSlug
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'cancelledAt',
          'status',
          'updatedAt',
        ]);
    }

    function safeChallengeDecline() {
      return resource.data.status == 'open'
        && resource.data.visibility == 'targeted'
        && isManager(resource.data.targetTeamClubSlug, resource.data.targetTeamSlug)
        && request.resource.data.status == 'declined'
        && request.resource.data.targetTeamClubSlug == resource.data.targetTeamClubSlug
        && request.resource.data.targetTeamSlug == resource.data.targetTeamSlug
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'declinedAt',
          'status',
          'updatedAt',
        ]);
    }

    function safeChallengeAccept(clubId) {
      return resource.data.status == 'open'
        && request.resource.data.status == 'accepted'
        && request.resource.data.acceptedByUid == request.auth.uid
        && request.resource.data.acceptedByTeamClubSlug is string
        && request.resource.data.acceptedByTeamSlug is string
        && isManager(request.resource.data.acceptedByTeamClubSlug, request.resource.data.acceptedByTeamSlug)
        && isApprovedClubTeam(clubId, request.resource.data.acceptedByTeamClubSlug, request.resource.data.acceptedByTeamSlug)
        && request.resource.data.createdByTeamClubSlug == resource.data.createdByTeamClubSlug
        && request.resource.data.createdByTeamSlug == resource.data.createdByTeamSlug
        && !(
          request.resource.data.acceptedByTeamClubSlug == resource.data.createdByTeamClubSlug
          && request.resource.data.acceptedByTeamSlug == resource.data.createdByTeamSlug
        )
        && (
          resource.data.visibility == 'open'
          || (
            request.resource.data.acceptedByTeamClubSlug == resource.data.targetTeamClubSlug
            && request.resource.data.acceptedByTeamSlug == resource.data.targetTeamSlug
          )
        )
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'acceptedAt',
          'acceptedByTeamClubSlug',
          'acceptedByTeamName',
          'acceptedByTeamSlug',
          'acceptedByUid',
          'awayGameId',
          'homeGameId',
          'status',
          'updatedAt',
        ]);
    }

    function safeChallengeGameCreate(clubId, teamId) {
      let challenge = challengeAfter(request.resource.data.challengeClubSlug, request.resource.data.challengeId).data;
      return signedIn()
        && request.resource.data.challengeClubSlug is string
        && request.resource.data.challengeId is string
        && challenge.status == 'accepted'
        && challenge.acceptedByUid == request.auth.uid
        && (
          (
            clubId == challenge.createdByTeamClubSlug
            && teamId == challenge.createdByTeamSlug
            && request.resource.data.linkedGameId == challenge.awayGameId
          )
          || (
            clubId == challenge.acceptedByTeamClubSlug
            && teamId == challenge.acceptedByTeamSlug
            && request.resource.data.linkedGameId == challenge.homeGameId
          )
        );
    }

    match /users/{uid} {
      allow read, create: if isSelf(uid);
      allow update: if isSelf(uid) && request.resource.data.uid == resource.data.uid;

      match /memberships/{membershipId} {
        allow read, create, update: if isSelf(uid);
        allow delete: if isSelf(uid) || isPlatformAdmin();
      }
    }

    match /platformAdmins/{uid} {
      allow read: if isSelf(uid) || isPlatformAdmin();
      allow write: if isPlatformAdmin();
    }

    match /{path=**}/teams/{teamId} {
      allow read: if signedIn();
    }

    match /clubs/{clubId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.slug == clubId
        && request.resource.data.status == 'active'
        && (isReservedClubCreate(clubId) || isPlatformAdmin());
      allow update: if isPlatformAdmin()
        && request.resource.data.slug == resource.data.slug;
      allow delete: if isPlatformAdmin() && clubId != 'independent';

      match /admins/{uid} {
        allow read: if signedIn();
        allow write: if isPlatformAdmin();
      }

      match /affiliationRequests/{requestId} {
        allow read: if isClubApprover(clubId)
          || isManager(resource.data.teamClubSlug, resource.data.teamSlug);
        allow create: if signedIn()
          && request.resource.data.requestedClubSlug == clubId
          && request.resource.data.clubSlug == clubId
          && request.resource.data.status == 'pending'
          && request.resource.data.teamClubSlug is string
          && request.resource.data.teamSlug is string
          && isManager(request.resource.data.teamClubSlug, request.resource.data.teamSlug);
        allow update: if isClubApprover(clubId)
          && request.resource.data.teamClubSlug == resource.data.teamClubSlug
          && request.resource.data.teamSlug == resource.data.teamSlug
          && request.resource.data.requestedClubSlug == resource.data.requestedClubSlug
          && request.resource.data.clubSlug == resource.data.clubSlug
          && request.resource.data.status in ['approved', 'rejected']
          && request.resource.data.reviewedBy == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'reviewedAt',
            'reviewedBy',
            'status',
            'updatedAt',
          ]);
        allow delete: if isPlatformAdmin();
      }

      match /challenges/{challengeId} {
        allow read: if signedIn();
        allow create: if safeChallengeCreate(clubId);
        allow update: if safeChallengeAccept(clubId)
          || safeChallengeDecline()
          || safeChallengeCancel();
        allow delete: if isPlatformAdmin();
      }

      match /teams/{teamId} {
        allow read: if signedIn();
        allow create: if signedIn()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.clubId == clubId
          && request.resource.data.slug == teamId
          && request.resource.data.status == 'active';
        allow update: if (
            isManager(clubId, teamId)
            && request.resource.data.clubId == resource.data.clubId
            && request.resource.data.slug == resource.data.slug
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'affiliationStatus',
              'joinCode',
              'logoPath',
              'logoUrl',
              'name',
              'primaryLocation',
              'requestedClubName',
              'requestedClubSlug',
              'status',
              'updatedAt',
            ])
            && (
              !request.resource.data.diff(resource.data).affectedKeys().hasAny([
                'affiliationStatus',
                'requestedClubName',
                'requestedClubSlug',
              ])
              || request.resource.data.affiliationStatus == 'pending'
            )
          )
          || (
            isClubApprover(resource.data.requestedClubSlug)
            && request.resource.data.clubId == resource.data.clubId
            && request.resource.data.slug == resource.data.slug
            && request.resource.data.createdBy == resource.data.createdBy
            && request.resource.data.affiliationStatus in ['approved', 'rejected']
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
              'affiliationStatus',
              'approvedAt',
              'approvedBy',
              'approvedClubSlug',
              'requestedClubSlug',
              'updatedAt',
            ])
          );
        allow delete: if isPlatformAdmin();

        match /members/{uid} {
          allow read: if isSelf(uid) || isTeamMember(clubId, teamId) || isAdminContext();
          allow create: if signedIn()
            && request.auth.uid == uid
            && request.resource.data.uid == uid
            && request.resource.data.clubId == clubId
            && request.resource.data.teamId == teamId
            && request.resource.data.teamSlug == teamId
            && request.resource.data.role in ['captain', 'member']
            && request.resource.data.status == 'active';
          allow update: if safeSelfMembershipUpdate(uid)
            || safeManagerMembershipSync(uid, clubId, teamId)
            || safeCaptainRoleUpdate(uid, clubId, teamId);
          allow delete: if isPlatformAdmin();
        }

        match /players/{playerId} {
          allow read: if isTeamMember(clubId, teamId) || isAdminContext();
          allow create: if safeSelfPlayerWrite(playerId, teamId);
          allow update: if isManager(clubId, teamId) || safeSelfPlayerWrite(playerId, teamId);
          allow delete: if isPlatformAdmin();
        }

        match /playerLinks/{uid} {
          allow read: if isSelf(uid) || isManager(clubId, teamId) || isPlatformAdmin();
          allow create, update: if safeSelfPlayerLinkWrite(uid, teamId) || isManager(clubId, teamId);
          allow delete: if isPlatformAdmin();
        }

        match /games/{gameId} {
          allow read: if isTeamMember(clubId, teamId) || isPlatformAdmin();
          allow create: if isManager(clubId, teamId) || safeChallengeGameCreate(clubId, teamId);
          allow update: if isManager(clubId, teamId) || isPlatformAdmin() || safeSelfAvailabilityUpdate(clubId, teamId);
          allow delete: if isManager(clubId, teamId) || isPlatformAdmin();
        }

        match /newsPosts/{postId} {
          allow read: if isTeamMember(clubId, teamId) || isPlatformAdmin();
          allow create, update, delete: if isManager(clubId, teamId) || isPlatformAdmin();
        }
      }
    }
  }
}
