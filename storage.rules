rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function memberPath(clubId, teamId) {
      return /databases/(default)/documents/clubs/$(clubId)/teams/$(teamId)/members/$(request.auth.uid);
    }

    function isTeamMember(clubId, teamId) {
      return signedIn() && firestore.exists(memberPath(clubId, teamId));
    }

    function hasTeamRole(clubId, teamId, roles) {
      return isTeamMember(clubId, teamId)
        && firestore.get(memberPath(clubId, teamId)).data.role in roles;
    }

    function isPlatformAdmin() {
      return signedIn() && request.auth.token.email in ['demandgendave@gmail.com'];
    }

    match /clubs/{clubId}/teams/{teamId}/news/{postId}/{fileName} {
      allow read: if isTeamMember(clubId, teamId);
      allow write: if isTeamMember(clubId, teamId) || isPlatformAdmin();
    }

    match /clubs/{clubId}/teams/{teamId}/branding/{fileName} {
      allow read: if isTeamMember(clubId, teamId) || isPlatformAdmin();
      allow write: if hasTeamRole(clubId, teamId, ['captain', 'coCaptain']) || isPlatformAdmin();
    }

    match /clubs/{clubId}/teams/{teamId}/players/{playerId}/headshots/{fileName} {
      allow read: if isTeamMember(clubId, teamId);
      allow write: if (
        isTeamMember(clubId, teamId)
        && firestore.get(memberPath(clubId, teamId)).data.playerId == playerId
      ) || isPlatformAdmin();
    }

    match /users/{uid}/profile/headshots/{fileName} {
      allow read: if signedIn();
      allow write: if (signedIn() && request.auth.uid == uid) || isPlatformAdmin();
    }

    match /clubs/{clubId}/branding/{fileName} {
      allow read: if true;
      allow write: if isPlatformAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
